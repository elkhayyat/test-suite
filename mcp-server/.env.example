# MCP Server Environment Configuration

# Server Configuration
PORT=3002
NODE_ENV=development

# Test Flow Suite API Configuration
TEST_FLOW_API_URL=http://localhost:3001
TEST_FLOW_AUTH_TOKEN=your-test-flow-auth-token

# MCP Authentication
MCP_AUTH_TOKEN=your-secure-mcp-auth-token

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend.com

# Logging
LOG_LEVEL=info

# Cloud Provider Specific (uncomment as needed)
# AWS_REGION=us-east-1
# GCP_PROJECT_ID=your-project
# AZURE_SUBSCRIPTION_ID=your-subscription