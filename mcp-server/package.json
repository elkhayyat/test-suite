{
  "name": "@test-flow-suite/mcp-server",
  "version": "1.0.0",
  "description": "MCP server for Test Flow Suite - enables OpenAPI flow creation, test execution, and analysis",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "test-flow-mcp": "./bin/test-flow-mcp"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:cloud": "tsx watch src/index-cloud.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:cloud": "node dist/index-cloud.js",
    "generate-token": "node scripts/generate-token.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "axios": "^1.7.9",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "openapi-types": "^12.1.3",
    "@apidevtools/swagger-parser": "^10.1.0",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.6",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}