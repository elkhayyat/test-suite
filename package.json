{
  "name": "test-flow-suite",
  "version": "1.0.0",
  "description": "Web-based test suite for creating and running test flows",
  "private": true,
  "workspaces": [
    "backend",
    "frontend",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:mongo": "concurrently \"npm run dev:mongo --workspace=backend\" \"npm run dev:frontend\"",
    "dev:backend": "npm run dev --workspace=backend",
    "dev:backend:mongo": "npm run dev:mongo --workspace=backend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "build": "npm run build --workspaces",
    "start": "npm run start --workspace=backend",
    "start:mongo": "npm run start:mongo --workspace=backend",
    "test": "npm run test --workspaces",
    "test:frontend": "npm run test --workspace=frontend",
    "test:backend": "npm run test --workspace=backend",
    "test:coverage": "npm run test:coverage --workspaces"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}